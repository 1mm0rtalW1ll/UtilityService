<Page x:Class="UtilityServiceApp.Pages.EditRequestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Редактирование заявки"
      Background="{StaticResource MainBrush}">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border Background="{StaticResource SecondaryBrush}" 
                Padding="25" CornerRadius="15" Width="600"
                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock x:Name="TxtHeader" Text="Новая заявка" FontSize="22" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#333"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Дом (Адрес):"/>
                        <ComboBox x:Name="ComboBuilding" 
                                  DisplayMemberPath="AddressLine" 
                                  SelectedValuePath="BuildingID" 
                                  SelectedValue="{Binding BuildingID}"/>

                        <TextBlock Text="Квартира:" Margin="0,10,0,0"/>
                        <TextBox Text="{Binding ApartmentNumber}" PreviewTextInput="TextBox_PreviewTextInput"/>

                        <TextBlock Text="Заявитель (ФИО):" Margin="0,10,0,0"/>
                        <ComboBox x:Name="ComboResident" 
                                  DisplayMemberPath="FullName" 
                                  IsEditable="True"
                                  SelectionChanged="ComboResident_SelectionChanged"/>

                        <TextBlock Text="Телефон:" Margin="0,10,0,0"/>
                        <TextBox x:Name="TxtPhone" Text="{Binding Residents.Phone}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Исполнитель:"/>
                        <ComboBox x:Name="ComboExecutor" 
                                  DisplayMemberPath="FullName" 
                                  SelectedValuePath="UserID" 
                                  SelectedValue="{Binding ExecutorID}"/>

                        <TextBlock Text="Статус:" Margin="0,10,0,0"/>
                        <ComboBox x:Name="ComboStatus" 
                                  DisplayMemberPath="StatusName" 
                                  SelectedValuePath="StatusID" 
                                  SelectedValue="{Binding StatusID}"/>

                        <StackPanel x:Name="PanelCompletion" Margin="0,10,0,0">
                            <TextBlock Text="Дата завершения:"/>
                            <DatePicker SelectedDate="{Binding CompletionDate}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="5,15,5,5">
                        <TextBlock Text="Описание проблемы:"/>
                        <TextBox Text="{Binding Description}" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>
                </Grid>

                <UniformGrid Columns="3" Margin="0,20,0,0">
                    <Button Content="Сохранить" Click="BtnSave_Click" Height="40" Margin="2"/>
                    <Button x:Name="BtnDelete" Content="Удалить" Click="BtnDelete_Click" 
                            Background="#E57373" Foreground="White" Height="40" Margin="2"/>
                    <Button Content="Отмена" Click="BtnCancel_Click" Background="#90A4AE" Height="40" Margin="2"/>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</Page>