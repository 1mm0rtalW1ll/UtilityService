<Page x:Class="UtilityServiceApp.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Авторизация">

    <Grid Background="{StaticResource MainBrush}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="260">
            <Image Source="/Resources/logo.png" Height="100" Margin="0,0,0,20" Stretch="Uniform"/>

            <TextBlock Text="Логин:" Margin="5,0"/>
            <TextBox x:Name="TxtLogin" Margin="0,5"/>

            <TextBlock Text="Пароль:" Margin="5,10,5,0"/>
            <PasswordBox x:Name="PbPassword" Margin="0,5"/>

            <Button x:Name="BtnLogin" Content="Войти" Cursor="Hand" Margin="0,20,0,5" Height="30" Click="BtnLogin_Click"/>

            <Button x:Name="BtnGuest" 
                    Content="Войти как клиент УК" 
                    Background="Transparent" 
                    Foreground="{StaticResource AccentBrush}" 
                    BorderThickness="0" 
                    Cursor="Hand"
                    Margin="0,10,0,0" 
                    Click="BtnGuest_Click">
            </Button>
        </StackPanel>
    </Grid>
</Page>