<Page x:Class="UtilityServiceApp.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Главная страница" Loaded="Page_Loaded">

    <Grid Background="{StaticResource MainBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}" Padding="10">
            <StackPanel>
                <DockPanel LastChildFill="False" Margin="0,0,0 ,10">
                    <StackPanel x:Name="AdminPanel" Orientation="Horizontal" Visibility="Collapsed">
                        <Button Content="Добавить заявку" Click="BtnAdd_Click" MinWidth="150" Margin="0,0,10,0"/>
                        <Button Content="История (Выполненные)" Click="BtnHistory_Click" MinWidth="180"/>
                    </StackPanel>
                    <Button Content="Выйти" DockPanel.Dock="Right" Click="BtnLogout_Click" MinWidth="100"/>
                </DockPanel>

                <StackPanel x:Name="FiltersPanel" Orientation="Horizontal">
                    <StackPanel x:Name="PanelFilterExecutor" Orientation="Horizontal">
                        <TextBlock Text="Сотрудник:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox x:Name="ComboFilterExecutor" Width="180" Margin="0,0,15,0"
                                  DisplayMemberPath="FullName" SelectedValuePath="UserID" 
                                  SelectionChanged="Filter_Changed"/>
                    </StackPanel>

                    <TextBlock Text="Адрес:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="ComboFilterAddress" Width="220" Margin="0,0,15,0"
                              DisplayMemberPath="AddressLine" SelectedValuePath="BuildingID" 
                              SelectionChanged="Filter_Changed"/>

                    <Button Content="Сбросить" Click="BtnReset_Click" Width="100" Background="#90A4AE"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid x:Name="DgRequests" Grid.Row="1" Margin="10"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  Background="White" MouseDoubleClick="DgRequests_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding RequestID}" Width="40"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat=\{0:dd.MM.yyyy\}}" Width="80"/>
                <DataGridTextColumn x:Name="ColAddress" Header="Адрес" Width="1.5*">
                    <DataGridTextColumn.Binding>
                        <MultiBinding StringFormat="д. {0}, кв. {1}">
                            <Binding Path="Buildings.AddressLine" />
                            <Binding Path="ApartmentNumber" />
                        </MultiBinding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn x:Name="ColFio" Header="Заявитель" Binding="{Binding Residents.FullName}" Width="*"/>
                <DataGridTextColumn x:Name="ColPhone" Header="Телефон" Binding="{Binding Residents.Phone}" Width="120"/>
                <DataGridTextColumn x:Name="ColDesc" Header="Описание" Binding="{Binding Description}" Width="2*"/>
                <DataGridTextColumn x:Name="ColExecutor" Header="Исполнитель" Binding="{Binding Users.FullName}" Width="*"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Statuses.StatusName}" Width="Auto">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Margin" Value="5,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Popup x:Name="WelcomePopup" Placement="Center" AllowsTransparency="True" StaysOpen="False">
            <Border Background="{StaticResource AccentBrush}" CornerRadius="8" Padding="30,20">
                <StackPanel>
                    <TextBlock Text="Успешная авторизация" Foreground="White" FontSize="12" Opacity="0.8" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtWelcome" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,5,0,0" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Page>